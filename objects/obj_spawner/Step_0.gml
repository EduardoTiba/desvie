///@description Diminuindo o intervalo de geração dos meteoros:

if (global.pontos == 40)
{
	tempo_geracao = 52;
}

if (global.pontos == 60)
{
	tempo_geracao = 50;
}

if (global.pontos == 80)
{
	tempo_geracao = 46;
}

if (global.pontos == 100)
{
	tempo_geracao = 44;
}

if (global.pontos == 150)
{
	tempo_geracao = 42;
}
show_debug_message(tempo_geracao);